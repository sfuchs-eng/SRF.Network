{
    "Comment": "Make sure to override with your local ~/.config/SRF.Network.json file",
    "Logging": {
        "LogLevel": {
            "Default": "Information",
            "Microsoft": "Warning",
            "Microsoft.Hosting.Lifetime": "Information",
            "Falcon": "Warning",
            "SRF.Network": "Trace",
            "SRF.Network.Knx.Connection": "Trace",
            "SRF.Knx.Config": "Information",
            "SRF.Knx.Config.OpenHab.Templating.ConfigTemplatesManager": "Information",
            "SRF.Knx.Config.OpenHab": "Information",
            "SRF": "Information"
        }
    },
    "Knx": {
        "Connections": {
            "default": {
                "ConnectionString:Comment": "Type=IpRouting,AutoReconnect=true,KnxAddress=0.0.20",
                "MulticastLoopback": false,
                "ConnectionManager": {
                    "AutoConnect": true,
                    "ReconnectInterval": 10.0
                }
            }
        },
        "System": {
            "EtsGAExportFile:Comment": "Filename to the XML export of your KNX project's Group Addresses from ETS, version 5",
            "KnxMasterFolder:Comment": "Directory path which must contain the file knx_master.xml that is distributed with the ETS software.",
            "OpenHab": {
                "WaitTimeBeforeWritingThingsFileSec": 1
            }
        }
    },
    "OpenHAB": {
        "WebSocket": "ws://<hostname>:8080/ws",
        "RestApi": "http://<hostname>:8080/rest/",
        "AccessToken": "<access token, generate in OpenHAB web UI>",
        "SourceEntity": "SRF.Network.OpenHab:TestClient"
    }
}
